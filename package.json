{
  "name": "autocarl",
  "version": "0.1.0",
  "description": "Automates crew-site timecard entry and expense-report PDF filling",
  "main": "out/main/index.js",
  "author": "John (teamsomo)",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "dist": "electron-vite build && electron-builder -mw",
    "dist:mac": "electron-vite build && electron-builder --mac --arm64 --x64",
    "dist:win": "electron-vite build && electron-builder --win --x64",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "keytar": "^7.9.0",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.48.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  },
  "build": {
    "appId": "com.teamsomo.autocarl",
    "productName": "AUTOcarl",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "out/**/*",
      "!**/{.eslintrc.cjs,.prettierrc,.gitignore}"
    ],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        { "target": "portable", "arch": ["x64"] }
      ],
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  }
}
